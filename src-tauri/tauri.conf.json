{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Smart Gate",
  "version": "0.1.0",
  "identifier": "com.plp.smartgate",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Smart Gate",
        "width": 800,
        "height": 600,
        "fullscreen": true,
        "resizable": false,
        "decorations": false,
        "additionalBrowserArgs": "--use-fake-ui-for-media-stream"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "models/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}